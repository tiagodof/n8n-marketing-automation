# n8n instance
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# OpenAI
OPENAI_API_KEY=sk-...

# Google Analytics 4
GA4_PROPERTY_ID=123456789
# Path to your Google service account JSON key (base64 encoded for n8n env)
GOOGLE_SERVICE_ACCOUNT_KEY=...

# Meta Ads
META_APP_ID=...
META_APP_SECRET=...
META_ACCESS_TOKEN=...
META_AD_ACCOUNT_ID=act_...

# LinkedIn Ads
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_ACCESS_TOKEN=...

# Email delivery (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=...
REPORT_RECIPIENT_EMAIL=recipient@email.com
